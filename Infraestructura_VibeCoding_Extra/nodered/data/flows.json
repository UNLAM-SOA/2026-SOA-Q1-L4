  {
    "id": "fn_cmd",
    "type": "function",
    "z": "tab_alarma",
    "name": "Comando -> MQTT",
    "func": "const cmd = (msg.req.query.cmd || '').toUpperCase();\nconst validos = ['ARM','DISARM','PANIC'];\nif (!validos.includes(cmd)) { msg.statusCode = 400; msg.payload = {ok:false, error:'cmd invalido'}; return [null, msg]; }\n// Mensaje a publicar por MQTT\nconst out = { topic: 'alarma/comando', payload: cmd };\nconst resp = { statusCode: 200, payload: {ok:true, cmd} };\nreturn [out, resp];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 520,
    "wires": [
      [
        "out_comando"
      ],
      [
        "resp_cmd"
      ]
    ]
