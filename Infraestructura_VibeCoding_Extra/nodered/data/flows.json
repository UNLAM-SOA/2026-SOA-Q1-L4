  {
    "id": "tmpl_panel",
    "type": "template",
    "z": "tab_alarma",
    "name": "panel HTML",
    "field": "payload",
    "fieldType": "msg",
    "format": "handlebars",
    "syntax": "plain",
    "template": "<!DOCTYPE html>\n<html lang=\\\"es\\\"><head><meta charset=\\\"utf-8\\\"><meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1\\\">\n<title>Alarma Antirrobos</title>\n<style>\n body{font-family:system-ui,Arial,sans-serif;margin:0;background:#0f172a;color:#e2e8f0}\n .wrap{max-width:760px;margin:0 auto;padding:20px}\n h1{font-size:1.4rem} .estado{font-size:2rem;font-weight:700;padding:16px;border-radius:12px;text-align:center;margin:12px 0}\n .APAGADO{background:#334155} .ACTIVO{background:#15803d} .ADVERTENCIA{background:#b45309} .ALERTADO{background:#b91c1c;animation:p .8s infinite}\n @keyframes p{50%{opacity:.5}}\n button{font-size:1rem;padding:10px 16px;margin:4px;border:0;border-radius:8px;cursor:pointer;color:#fff}\n .arm{background:#15803d}.dis{background:#475569}.pan{background:#b91c1c}\n table{width:100%;border-collapse:collapse;margin-top:14px;font-size:.85rem}\n th,td{border-bottom:1px solid #334155;padding:6px;text-align:left}\n .muted{color:#94a3b8;font-size:.85rem}\n</style></head>\n<body><div class=\\\"wrap\\\">\n<h1>Dispositivo IoT Antirrobos &mdash; Panel local</h1>\n<div id=\\\"estado\\\" class=\\\"estado APAGADO\\\">--</div>\n<div class=\\\"muted\\\">Magnitud acel.: <span id=\\\"acel\\\">-</span> m/s&sup2;</div>\n<div style=\\\"margin:14px 0\\\">\n <button class=\\\"arm\\\" onclick=\\\"cmd('ARM')\\\">ARMAR</button>\n <button class=\\\"dis\\\" onclick=\\\"cmd('DISARM')\\\">DESARMAR</button>\n <button class=\\\"pan\\\" onclick=\\\"cmd('PANIC')\\\">PANICO</button>\n</div>\n<h2 style=\\\"font-size:1.1rem\\\">Historial de activaciones</h2>\n<table id=\\\"hist\\\"><thead><tr><th>#</th><th>Fecha</th><th>Tipo</th><th>Estado</th><th>Detalle</th></tr></thead><tbody></tbody></table>\n<script>\nasync function cmd(c){ await fetch('/alarma/comando?cmd='+c); refresh(); }\nasync function refresh(){\n try{\n  const e=await (await fetch('/alarma/estado')).json();\n  const est=(e.estado&&e.estado.estado)||'--';\n  const d=document.getElementById('estado'); d.textContent=est+' '+((e.estado&&e.estado.modo)||''); d.className='estado '+est;\n  document.getElementById('acel').textContent=(e.acel&&e.acel.magnitud!=null)?Number(e.acel.magnitud).toFixed(2):'-';\n  const h=await (await fetch('/alarma/historial')).json();\n  const tb=document.querySelector('#hist tbody'); tb.innerHTML='';\n  (h||[]).forEach(r=>{ const tr=document.createElement('tr');\n   tr.innerHTML='<td>'+r.id+'</td><td>'+(r.ts||'')+'</td><td>'+(r.tipo||'')+'</td><td>'+(r.estado||'')+'</td><td>'+(r.detalle||'')+'</td>'; tb.appendChild(tr);});\n }catch(err){console.error(err);}\n}\nsetInterval(refresh,2000); refresh();\n</script>\n</div></body></html>",
    "output": "str",
    "x": 400,
    "y": 800,
