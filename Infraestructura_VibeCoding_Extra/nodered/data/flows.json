    "type": "function",
    "z": "tab_alarma",
    "name": "SQL crear tabla",
    "func": "// Crea la tabla de historial si no existe (se ejecuta al desplegar el flujo)\nmsg.topic = `CREATE TABLE IF NOT EXISTS activaciones (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  ts TEXT DEFAULT (datetime('now','localtime')),\n  tipo TEXT,\n  estado TEXT,\n  modo TEXT,\n  detalle TEXT,\n  origen TEXT\n)`;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
