#!/bin/sh
# Gradle start up script for POSIX (Gradle wrapper 8.7).
# NOTA: requiere gradle/wrapper/gradle-wrapper.jar. Android Studio lo genera
# automaticamente al abrir el proyecto (Sync). Tambien podes generarlo con:
#     gradle wrapper --gradle-version 8.7
set -e
APP_HOME=$(cd "$(dirname "$0")" && pwd -P)
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
if [ -z "$JAVA_HOME" ]; then JAVACMD=java; else JAVACMD="$JAVA_HOME/bin/java"; fi
exec "$JAVACMD" -Dorg.gradle.appname="gradlew" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
