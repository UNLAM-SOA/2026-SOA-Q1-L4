    {
        "id": "6addf687a458e573",
        "type": "mqtt in",
        "z": "979efe57d89b88fc",
        "name": "",
        "topic": "alarm/arm_dsrm",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "73755068f3bfb81c",
        "nl": false,
        "rap": true,
        "rh": 0,
