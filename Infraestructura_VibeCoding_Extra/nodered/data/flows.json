  {
    "id": "fn_estado",
    "type": "function",
    "z": "tab_alarma",
    "name": "Estado -> SQL",
    "func": "const q = s => String(s===undefined||s===null?'':s).replace(/'/g,\"''\");\nlet p = msg.payload; if (typeof p === 'string') { try { p = JSON.parse(p); } catch(e){ p={estado:p}; } }\nconst estado = p.estado || '';\nconst modo = p.modo || '';\n// Guardar ultimo estado en contexto para el panel web\nflow.set('ultimoEstado', {estado, modo, ts: new Date().toISOString()});\nmsg.topic = `INSERT INTO activaciones (tipo,estado,modo,detalle,origen) VALUES ('estado','${q(estado)}','${q(modo)}','','esp32')`;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
