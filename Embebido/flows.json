    {
        "id": "c08df66c16f20e36",
        "type": "function",
        "z": "979efe57d89b88fc",
        "name": "function 2",
        "func": "// 1. Leemos el estado actual de la variable \"estadoAlarma\".\n// Si es la primera vez y todavía no existe, le asignamos \"DISARM\" por defecto.\nlet estadoActual = flow.get(\"estadoAlarma\") ?? \"DISARM\";\n\n// 2. Definimos el nuevo estado invirtiendo el valor actual\nlet nuevoEstado;\nif (estadoActual === \"ARM\") {\n    nuevoEstado = \"DISARM\";\n} else {\n    nuevoEstado = \"ARM\";\n}\n\n// 3. Guardamos el nuevo string en el contexto de flujo para la próxima vez\nflow.set(\"estadoAlarma\", nuevoEstado);\n\n// 4. Modificamos el msg.payload con el nuevo estado (\"ARM\" o \"DISARM\") \n// para que los nodos que siguen (como un envío MQTT de vuelta) lo usen\nmsg.payload = nuevoEstado;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 540,
        "wires": [
