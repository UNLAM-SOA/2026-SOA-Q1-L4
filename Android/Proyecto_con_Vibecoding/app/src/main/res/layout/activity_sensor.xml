<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_sensor"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/instruccion_shake"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <TextView
        android:id="@+id/txtValores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/xyz_inicial"
        android:textSize="18sp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/txtSacudidas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sacudidas_inicial"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingTop="24dp" />

    <TextView
        android:id="@+id/txtUltima"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/guion"
        android:gravity="center"
        android:paddingTop="12dp"
        android:textColor="#B91C1C" />

</LinearLayout>
